# ================================================================
# CAIA Backend Environment Configuration
# ================================================================
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ================================================================

# ======================== Server Configuration ====================
# Port on which the server runs (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# ======================== Database Configuration ==================
# MongoDB connection URI
# Local: mongodb://127.0.0.1:27017/caia_db
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/caia_db?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/caia_db

# ======================== JWT Configuration ======================
# Secret key for signing JWT tokens (use a strong random string in production)
# Minimum 32 characters recommended
JWT_SECRET=caia_jwt_secret_key_2026_xyz_change_this_in_production

# JWT token expiration time (e.g., 24h, 7d, 1w)
JWT_EXPIRE=24h

# Password reset token expiration (in minutes)
PASSWORD_RESET_EXPIRE=30

# Email verification token expiration (in minutes)
EMAIL_VERIFY_EXPIRE=60

# ======================== CORS Configuration =====================
# Comma-separated list of allowed origins for CORS
# Example: http://localhost:3000,http://localhost:3001,https://example.com
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ======================== Rate Limiting ===========================
# Rate limit window in minutes
RATE_LIMIT_WINDOW_MS=15

# Maximum requests per IP in the rate limit window
RATE_LIMIT_MAX_REQUESTS=1000

# ======================== Logging & Monitoring ====================
# Log level (debug, info, warn, error)
LOG_LEVEL=debug

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# ======================== Email Configuration (Optional) ===========
# Email service for password reset and verification
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@caia.com

# ======================== Analytics & Monitoring ===================
# Enable analytics collection
ENABLE_ANALYTICS=true

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://your-key@sentry.io/project-id

# ======================== Cache Configuration (Optional) ===========
# Redis URL for caching (optional)
# REDIS_URL=redis://localhost:6379

# ======================== API Documentation =======================
# Enable Swagger/OpenAPI documentation
ENABLE_SWAGGER=true

# Swagger API version
SWAGGER_VERSION=1.0.0

